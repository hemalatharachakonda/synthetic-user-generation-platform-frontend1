# Copy this file to .env and fill in real values when you're ready to go live.

# Set to "false" once your backend is ready
USE_MOCK_DATA=true

# Your real backend base URL (Spring Boot / FastAPI / whatever you build)
BACKEND_BASE_URL=http://localhost:8000/api

# Only needed if THIS frontend calls Groq directly instead of going through your backend
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
